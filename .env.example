# ============================================================================
# NZ Lotto Wheel Analysis — Environment Variables (.env.example)
# ============================================================================
# Copy this file to .env and fill in your values.
# Every variable can also be set as a regular environment variable.
# ============================================================================

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
# JWT_SECRET_KEY=change-me-in-production-lotto-app-secret
# JWT_EXPIRE_MINUTES=120
# JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# Admin credentials (initial admin account created on first run)
# ---------------------------------------------------------------------------
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# SMTP / Email Notifications
# ---------------------------------------------------------------------------
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=your-email@gmail.com
# ALERT_EMAIL_TO=your-email@gmail.com

# ---------------------------------------------------------------------------
# Prize Pool & Allocation
# ---------------------------------------------------------------------------
# PRIZE_POOL_RATIO=0.75               # Fraction of turnover → prize pool
# RESERVE_LOTTO=0.25                  # Reserve fraction for Lotto
# RESERVE_POWERBALL=0.25              # Reserve fraction for Powerball
# DIV1_CAP=50000000                   # $50M maximum per Div 1 winner
# MAX_CONSECUTIVE_JACKPOTS=10         # Max Div 1 rollovers before must-win
# DIV7_PB_PRIZE=15.0                  # Fixed Div 7 Powerball prize (NZD)
# DIV7_LOTTO_PRIZE=2.80               # Fixed Div 7 Lotto prize (NZD)
# DEFAULT_LOTTO_POOL=215000           # Fallback Lotto pool estimate
# DEFAULT_POWERBALL_TURNOVER=2500000  # Fallback Powerball turnover estimate

# ---------------------------------------------------------------------------
# Selenium / ChromeDriver
# ---------------------------------------------------------------------------
# SELENIUM_CHROME_BINARY=/usr/bin/google-chrome   # Full path to Chrome binary
# USE_SELENIUM_FALLBACK=false

# ---------------------------------------------------------------------------
# Rate Limits (FastAPI / slowapi)
# ---------------------------------------------------------------------------
# API_RATE_LIMIT=60/minute
# HEAVY_RATE_LIMIT=5/minute

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite:///lotto.db               # SQLite (default)
# DATABASE_URL=postgresql://user:pass@localhost/lotto  # PostgreSQL

# ---------------------------------------------------------------------------
# Paths (relative to the project root, or absolute)
# ---------------------------------------------------------------------------
# DB_PATH=lotto.db
# PRIZE_CACHE_FILE=prize_cache.json
# ALERT_LOG=alert.log

# ---------------------------------------------------------------------------
# External API
# ---------------------------------------------------------------------------
# API_BASE=https://pathway.mylotto.co.nz
# API_TIMEOUT=15
# POLITE_DELAY=2.0
# CACHE_TTL_DAYS=7

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
# DRAWS_PER_WEEK=2
# TICKET_COST=1.50
